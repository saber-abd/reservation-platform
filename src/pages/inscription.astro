---
import Layout from '@/layouts/Layout.astro';
import SignupForm from '@/components/auth/SignupForm';
---

<Layout title="Inscription" description="Créer votre espace professionnel." noindex>
	<section class="mx-auto max-w-md px-6 py-20">
		<h1 class="text-2xl font-bold text-gray-900">Créer votre espace professionnel</h1>
		<p class="mt-2 text-sm text-gray-500">
			Configurez votre profil, vos prestations et vos disponibilités.
		</p>
		<div class="mt-8">
			<SignupForm client:load />
		</div>
		<p class="mt-6 text-sm text-gray-500">
			Déjà un compte ? <a href="/connexion" class="font-medium text-blue-600 hover:underline">Se connecter</a>
		</p>
	</section>
</Layout>
