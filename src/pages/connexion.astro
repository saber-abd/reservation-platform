---
import Layout from '@/layouts/Layout.astro';
import LoginForm from '@/components/auth/LoginForm';
---

<Layout title="Connexion" description="Connexion à l'espace professionnel." noindex>
	<section class="mx-auto max-w-md px-6 py-20">
		<h1 class="text-2xl font-bold text-gray-900">Connexion professionnel</h1>
		<p class="mt-2 text-sm text-gray-500">Accédez à votre espace de gestion.</p>
		<div class="mt-8">
			<LoginForm client:load />
		</div>
		<p class="mt-6 text-sm text-gray-500">
			Pas encore de compte ? <a href="/inscription" class="font-medium text-blue-600 hover:underline">Créer un compte</a>
		</p>
	</section>
</Layout>
