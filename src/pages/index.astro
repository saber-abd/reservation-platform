---
import Layout from '@/layouts/Layout.astro';
import Map from '@/components/Map.astro';
import ServicesList from '@/components/ServicesList';
import { siteConfig } from '@/config/site';
---

<Layout>
	<!-- Hero -->
	<section class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-6 py-24 md:py-32">
		<p class="text-sm font-semibold uppercase tracking-widest text-rose-600">
			{siteConfig.business.activity}
		</p>
		<h1 class="max-w-2xl text-4xl font-bold tracking-tight text-stone-900 md:text-6xl">
			{siteConfig.business.tagline}
		</h1>
		<p class="max-w-xl text-lg text-stone-500">
			{siteConfig.business.description}
		</p>
		<a
			href="/reservation"
			class="rounded-xl bg-rose-600 px-6 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-rose-700"
		>
			Réserver maintenant
		</a>
	</section>

	<!-- Aperçu services -->
	<section class="bg-stone-50 py-20">
		<div class="mx-auto max-w-6xl px-6">
			<div class="mb-10 flex items-end justify-between" data-aos="fade-up">
				<h2 class="text-2xl font-bold text-stone-900 md:text-3xl">Nos prestations</h2>
				<a href="/services" class="text-sm font-medium text-rose-600 hover:underline">Voir tout</a>
			</div>
			<ServicesList client:load limit={4} showCta={false} />
		</div>
	</section>

	<!-- À propos résumé -->
	<section class="mx-auto max-w-6xl px-6 py-20">
		<div class="grid items-center gap-10 md:grid-cols-2">
			<div
				class="flex aspect-video items-center justify-center rounded-xl bg-stone-100 text-stone-400"
				data-aos="fade-right"
			>
				Photo du salon
			</div>
			<div data-aos="fade-left">
				<h2 class="text-2xl font-bold text-stone-900 md:text-3xl">À propos</h2>
				<p class="mt-4 text-stone-500">{siteConfig.business.description}</p>
				<a href="/a-propos" class="mt-4 inline-block text-sm font-medium text-rose-600 hover:underline">
					En savoir plus
				</a>
			</div>
		</div>
	</section>

	<!-- Avis clients -->
	<section class="bg-stone-50 py-20">
		<div class="mx-auto max-w-6xl px-6">
			<h2 class="mb-10 text-2xl font-bold text-stone-900 md:text-3xl" data-aos="fade-up">Avis clients</h2>
			<div class="grid gap-6 md:grid-cols-3">
				{
					siteConfig.testimonials.map((testimonial, index) => (
						<div
							class="rounded-xl border border-border bg-white p-6 shadow-sm"
							data-aos="fade-up"
							data-aos-delay={index * 75}
						>
							<p class="text-sm text-amber-500">{'★'.repeat(testimonial.rating)}</p>
							<p class="mt-3 text-sm text-stone-600">« {testimonial.comment} »</p>
							<p class="mt-4 text-sm font-semibold text-stone-900">{testimonial.name}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Où nous trouver -->
	<section class="mx-auto max-w-6xl px-6 py-20">
		<div class="grid items-center gap-10 md:grid-cols-2">
			<div data-aos="fade-right">
				<h2 class="text-2xl font-bold text-stone-900 md:text-3xl">Où nous trouver</h2>
				<p class="mt-4 text-stone-500">{siteConfig.business.address}</p>
				<a href="/contact" class="mt-4 inline-block text-sm font-medium text-rose-600 hover:underline">
					Voir les coordonnées complètes
				</a>
			</div>
			<div data-aos="fade-left">
				<Map lat={siteConfig.business.lat} lng={siteConfig.business.lng} label={siteConfig.business.name} />
			</div>
		</div>
	</section>

	<!-- CTA final -->
	<section class="mx-auto max-w-6xl px-6 py-20 text-center" data-aos="zoom-in">
		<h2 class="text-3xl font-bold text-stone-900 md:text-4xl">Prêt à prendre rendez-vous ?</h2>
		<p class="mt-4 text-stone-500">Réservez votre créneau en quelques clics.</p>
		<a
			href="/reservation"
			class="mt-6 inline-block rounded-xl bg-rose-600 px-6 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-rose-700"
		>
			Réserver maintenant
		</a>
	</section>
</Layout>

