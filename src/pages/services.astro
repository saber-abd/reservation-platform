---
import Layout from '@/layouts/Layout.astro';
import ServicesList from '@/components/ServicesList';
import { siteConfig } from '@/config/site';
---

<Layout title="Services" description={`Découvrez les prestations proposées par ${siteConfig.business.name}.`}>
	<section class="mx-auto max-w-6xl px-6 py-20">
		<h1 class="text-3xl font-bold text-stone-900 md:text-4xl">Nos prestations</h1>
		<p class="mt-3 max-w-2xl text-stone-500">
			Un aperçu de nos services. Contactez-nous pour toute demande sur-mesure.
		</p>

		<div class="mt-10">
			<ServicesList client:load />
		</div>

		<div class="mt-16 rounded-xl bg-stone-50 p-8 text-center" data-aos="fade-up">
			<p class="text-lg font-semibold text-stone-900">Une demande sur-mesure ?</p>
			<p class="mt-2 text-stone-500">Contactez-nous pour en discuter, nous nous adaptons à vos besoins.</p>
			<a href="/contact" class="mt-4 inline-block text-sm font-medium text-rose-600 hover:underline">
				Nous contacter
			</a>
		</div>
	</section>
</Layout>
