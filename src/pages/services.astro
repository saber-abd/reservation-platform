---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site';
---

<Layout title="Services" description={`Découvrez les prestations proposées par ${siteConfig.business.name}.`}>
	<section class="mx-auto max-w-6xl px-6 py-20">
		<h1 class="text-3xl font-bold text-gray-900 md:text-4xl">Nos prestations</h1>
		<p class="mt-3 max-w-2xl text-gray-500">
			Un aperçu de nos services. Contactez-nous pour toute demande sur-mesure.
		</p>

		<div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				siteConfig.services.map((service) => (
					<div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
						<p class="text-lg font-semibold text-gray-900">{service.name}</p>
						<p class="mt-2 flex-1 text-sm text-gray-500">{service.description}</p>
						<div class="mt-4 flex items-center justify-between border-t border-border pt-4 text-sm">
							<span class="text-gray-400">{service.durationMinutes} min</span>
							<span class="font-semibold text-gray-900">{service.price} €</span>
						</div>
						<a
							href="/reservation"
							class="mt-4 rounded-xl bg-blue-600 px-4 py-2 text-center text-sm font-semibold text-white transition-colors hover:bg-blue-700"
						>
							Réserver
						</a>
					</div>
				))
			}
		</div>

		<div class="mt-16 rounded-xl bg-gray-50 p-8 text-center">
			<p class="text-lg font-semibold text-gray-900">Une demande sur-mesure ?</p>
			<p class="mt-2 text-gray-500">Contactez-nous pour en discuter, nous nous adaptons à vos besoins.</p>
			<a href="/contact" class="mt-4 inline-block text-sm font-medium text-blue-600 hover:underline">
				Nous contacter
			</a>
		</div>
	</section>
</Layout>
