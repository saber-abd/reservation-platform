---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site';
---

<Layout title="Contact" description={`Contactez ${siteConfig.business.name}.`}>
	<section class="mx-auto max-w-6xl px-6 py-20">
		<h1 class="text-3xl font-bold text-gray-900 md:text-4xl">Contact</h1>
		<p class="mt-3 max-w-2xl text-gray-500">
			Une question ? Contactez-nous, nous vous répondrons dans les meilleurs délais.
		</p>

		<div class="mt-10 grid gap-10 md:grid-cols-2">
			<div>
				<div class="rounded-xl border border-border bg-white p-6 shadow-sm">
					<p class="font-semibold text-gray-900">Coordonnées</p>
					<ul class="mt-4 space-y-2 text-sm text-gray-500">
						<li>{siteConfig.business.address}</li>
						<li>{siteConfig.business.phone}</li>
						<li>{siteConfig.business.email}</li>
					</ul>
				</div>

				<div class="mt-6 flex aspect-video items-center justify-center rounded-xl bg-gray-100 text-gray-400">
					Carte / plan d'accès
				</div>
			</div>

			<!-- Formulaire visuel : la logique d'envoi sera branchée en Phase 5/6 (backend). -->
			<form class="flex flex-col gap-4 rounded-xl border border-border bg-white p-6 shadow-sm">
				<div>
					<label for="name" class="text-sm font-medium text-gray-900">Nom</label>
					<input
						id="name"
						name="name"
						type="text"
						required
						class="mt-1 w-full rounded-lg border border-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600"
					/>
				</div>
				<div>
					<label for="email" class="text-sm font-medium text-gray-900">Email</label>
					<input
						id="email"
						name="email"
						type="email"
						required
						class="mt-1 w-full rounded-lg border border-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600"
					/>
				</div>
				<div>
					<label for="message" class="text-sm font-medium text-gray-900">Message</label>
					<textarea
						id="message"
						name="message"
						rows="4"
						required
						class="mt-1 w-full rounded-lg border border-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600"
					></textarea>
				</div>
				<button
					type="submit"
					class="rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-blue-700"
				>
					Envoyer
				</button>
			</form>
		</div>
	</section>
</Layout>
