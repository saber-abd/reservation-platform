---
// Layout dédié aux espaces authentifiés (dashboard pro + espace client).
// Volontairement distinct du Layout public : pas de header/footer vitrine,
// juste une barre d'app minimale, pour bien différencier "site public" et "espace privé".
import '../styles/global.css';
import { Scissors, ArrowLeft } from 'lucide-react';
import { siteConfig } from '@/config/site';

interface Props {
	title?: string;
}

const { title = 'Espace' } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<title>{title} — {siteConfig.business.name}</title>
	</head>
	<body class="min-h-screen bg-stone-100 text-stone-900">
		<header class="border-b border-border bg-white">
			<div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3">
				<a href="/" aria-label={siteConfig.business.name} class="flex items-center gap-2">
					<span class="flex h-8 w-8 items-center justify-center rounded-full bg-rose-600 text-white">
						<Scissors size={16} />
					</span>
					<span class="text-sm font-semibold text-stone-900">{siteConfig.business.name}</span>
				</a>
				<a href="/" class="flex items-center gap-1 text-xs font-medium text-stone-500 hover:text-rose-600">
					<ArrowLeft size={14} />
					Retour au site
				</a>
			</div>
		</header>
		<main class="mx-auto max-w-5xl px-6 py-12">
			<slot />
		</main>
	</body>
</html>
