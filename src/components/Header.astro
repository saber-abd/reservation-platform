---
import { siteConfig } from '@/config/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
		<a href="/" class="text-lg font-bold tracking-tight text-gray-900">
			{siteConfig.business.name}
		</a>

		<nav class="hidden items-center gap-8 md:flex">
			{
				siteConfig.nav.map((item) => (
					<a
						href={item.href}
						class:list={[
							'text-sm font-medium transition-colors hover:text-blue-600',
							currentPath === item.href ? 'text-blue-600' : 'text-gray-600',
						]}
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<a
			href="/reservation"
			class="rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700"
		>
			Réserver
		</a>
	</div>
</header>
