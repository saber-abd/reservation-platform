---
import { Scissors, LogIn } from 'lucide-react';
import { siteConfig } from '@/config/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
		<a href="/" aria-label={siteConfig.business.name} class="flex items-center gap-2">
			<span class="flex h-9 w-9 items-center justify-center rounded-full bg-rose-600 text-white shadow-sm">
				<Scissors size={18} />
			</span>
			<span class="sr-only">{siteConfig.business.name}</span>
		</a>

		<nav class="hidden items-center gap-8 md:flex">
			{
				siteConfig.nav.map((item) => (
					<a
						href={item.href}
						class:list={[
							'text-sm font-medium transition-colors hover:text-rose-600',
							currentPath === item.href ? 'text-rose-600' : 'text-stone-600',
						]}
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<a
			href="/connexion"
			class="flex items-center gap-2 rounded-xl border border-border bg-white px-4 py-2 text-sm font-semibold text-stone-700 shadow-sm transition-colors hover:border-rose-300 hover:text-rose-600"
		>
			<LogIn size={16} />
			Connexion / Inscription
		</a>
	</div>
</header>
